# Copy this file to ".env" and fill in your keys. NEVER commit the real .env.
# Get test keys at: https://dashboard.stripe.com/test/apikeys

# Server-side secret key (test mode). KEEP THIS PRIVATE — server only.
STRIPE_SECRET_KEY=sk_test_your_key_here

# Optional: signing secret for the /api/stripe-webhook endpoint
# (Dashboard → Developers → Webhooks → your endpoint → Signing secret)
STRIPE_WEBHOOK_SECRET=

# Port the server listens on (matches the existing dev port)
PORT=4321

# Secret used to sign admin staff session cookies. Set a long random string
# in production. Falls back to a dev default if unset (fine for local only).
SESSION_SECRET=change-me-to-a-long-random-string

# Database (timber_db). Defaults below match a local XAMPP MariaDB.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=timber_db

# Email notifications (order status updates). OPTIONAL.
# Leave SMTP_HOST blank to run in "simulated" mode — messages are logged
# to the server console instead of being sent (no credentials needed).
# Fill these in to send real email via your SMTP provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TimberPro <no-reply@timberpro.local>
